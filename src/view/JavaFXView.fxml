<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


    <VBox spacing="12" xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="view.JavaFXController"
          stylesheets="@style.css">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="Knowledge Management System - Putusan Narkotika"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>

    <GridPane hgap="15" vgap="10">
        <Label text="Nomor Perkara:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNomorPerkara" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Nama Terdakwa:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtNamaTerdakwa" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Pengadilan:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="txtPengadilan" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Tanggal Putusan:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
        <TextField fx:id="txtTanggal" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        <Label text="Umur Terdakwa:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <TextField fx:id="txtUmur" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <Label text="Berat Barang Bukti:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
        <TextField fx:id="txtBerat" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

        <Label text="Pasal Dilanggar:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPasal" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Peran Terdakwa:" GridPane.rowIndex="4" GridPane.columnIndex="2"/>
        <TextField fx:id="txtPeran" GridPane.rowIndex="4" GridPane.columnIndex="3"/>

        <Label text="Vonis Denda:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="txtDenda" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Nama Hakim:" GridPane.rowIndex="5" GridPane.columnIndex="2"/>
        <TextField fx:id="txtHakim" GridPane.rowIndex="5" GridPane.columnIndex="3"/>

        <Label text="Jenis Narkotika:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtJenisNarkotika" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Vonis (bulan):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtVonis" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10">
        <TextField fx:id="txtCari" promptText="Ketik nomor perkara / nama terdakwa"/>
        <Button text="Cari" onAction="#handleCariPutusan"/>
        <Button text="Tambah Putusan" onAction="#handleTambahPutusan"/>
        <Button text="Hapus Putusan" onAction="#handleHapusPutusan"/>
        <Button text="Refresh" onAction="#handleRefresh"/>
        <Button fx:id="btnStatistik" text="Statistik" onAction="#handleTampilkanStatistik"/>
    </HBox>

    <TableView fx:id="tabelPutusan" VBox.vgrow="ALWAYS" prefHeight="300">
        <columns>
            <TableColumn fx:id="colNomor" text="Nomor Perkara" prefWidth="150"/>
            <TableColumn fx:id="colPengadilan" text="Pengadilan" prefWidth="120"/>
            <TableColumn fx:id="colTanggal" text="Tanggal Putusan" prefWidth="120"/>
            <TableColumn fx:id="colNama" text="Nama Terdakwa" prefWidth="150"/>
            <TableColumn fx:id="colUmur" text="Umur Terdakwa" prefWidth="100"/>
            <TableColumn fx:id="colJenis" text="Jenis Narkotika" prefWidth="180"/>
            <TableColumn fx:id="colBerat" text="Berat Barang Bukti" prefWidth="130"/>
            <TableColumn fx:id="colPasal" text="Pasal Dilanggar" prefWidth="200"/>
            <TableColumn fx:id="colPeran" text="Peran Terdakwa" prefWidth="200"/>
            <TableColumn fx:id="colVonis" text="Vonis (bulan)" prefWidth="100"/>
            <TableColumn fx:id="colDenda" text="Vonis Denda" prefWidth="130"/>
            <TableColumn fx:id="colHakim" text="Nama Hakim" prefWidth="300"/>
        </columns>
    </TableView>

    <Label fx:id="lblStatus" text=""/>
</VBox>